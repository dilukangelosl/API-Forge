{
    "name": "@dilukangelo/api-forge-adapter-express",
    "version": "0.1.1",
    "description": "Express adapter for API Forge",
    "author": "Diluk Angelo <dilukangelo@gmail.com>",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist --target node && tsc --emitDeclarationOnly --declaration --declarationDir ./dist",
        "dev": "bun --watch ./src/index.ts",
        "test": "bun test"
    },
    "peerDependencies": {
        "@dilukangelo/api-forge-core": "^0.1.0",
        "express": "^4.0.0 || ^5.0.0"
    },
    "devDependencies": {
        "@dilukangelo/api-forge-core": "workspace:*",
        "@types/bun": "latest",
        "@types/express": "^4.17.21",
        "express": "^4.18.0",
        "typescript": "^5.4.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dilukangelosl/API-Forge",
        "directory": "packages/adapter-express"
    },
    "keywords": [
        "api-forge",
        "express",
        "adapter",
        "oauth",
        "middleware"
    ]
}