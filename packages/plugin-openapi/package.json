{
    "name": "@dilukangelo/api-forge-plugin-openapi",
    "version": "0.1.3",
    "description": "OpenAPI 3.1 documentation generator for API Forge",
    "author": "Diluk Angelo <dilukangelo@gmail.com>",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts --packages external --outdir ./dist --target node && tsc --emitDeclarationOnly --declaration --declarationDir ./dist",
        "dev": "bun build ./src/index.ts --outdir ./dist --target node --watch"
    },
    "peerDependencies": {
        "@dilukangelo/api-forge-core": "^0.1.0"
    },
    "devDependencies": {
        "@dilukangelo/api-forge-core": "workspace:*",
        "typescript": "^5.7.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dilukangelosl/API-Forge",
        "directory": "packages/plugin-openapi"
    },
    "keywords": [
        "api-forge",
        "openapi",
        "swagger",
        "documentation",
        "api-docs"
    ]
}
