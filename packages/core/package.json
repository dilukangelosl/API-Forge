{
    "name": "@dilukangelo/api-forge-core",
    "version": "0.1.1",
    "description": "Core API Forge library - OAuth, rate limiting, docs, and portal",
    "author": "Diluk Angelo <dilukangelo@gmail.com>",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./storage/memory": {
            "types": "./dist/storage/memory.d.ts",
            "import": "./dist/storage/memory.js",
            "require": "./dist/storage/memory.js",
            "default": "./dist/storage/memory.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts ./src/storage/memory.ts --outdir ./dist --target node && tsc --emitDeclarationOnly --declaration --declarationDir ./dist",
        "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir ./dist",
        "dev": "bun --watch ./src/index.ts",
        "test": "bun test"
    },
    "dependencies": {
        "argon2": "^0.44.0",
        "jose": "^5.2.0",
        "zod": "^3.22.0"
    },
    "peerDependencies": {
        "ioredis": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "ioredis": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/express": "^4.17.21",
        "bun-types": "^1.3.8",
        "express": "^4.18.0",
        "typescript": "^5.4.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dilukangelosl/API-Forge",
        "directory": "packages/core"
    },
    "keywords": [
        "oauth",
        "oauth2",
        "api-gateway",
        "middleware",
        "typescript",
        "jwt",
        "rate-limiting"
    ]
}