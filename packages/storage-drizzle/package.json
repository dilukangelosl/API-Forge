{
    "name": "@dilukangelo/api-forge-storage-drizzle",
    "version": "0.1.1",
    "description": "Drizzle ORM storage adapter for API Forge OAuth",
    "author": "Diluk Angelo <dilukangelo@gmail.com>",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./schema": {
            "types": "./dist/schema.d.ts",
            "import": "./dist/schema.js",
            "require": "./dist/schema.js",
            "default": "./dist/schema.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts ./src/schema.ts --outdir ./dist --target node && tsc --emitDeclarationOnly --declaration --declarationDir ./dist",
        "dev": "bun --watch ./src/index.ts",
        "test": "bun test"
    },
    "peerDependencies": {
        "@dilukangelo/api-forge-core": ">=0.1.0",
        "drizzle-orm": "^0.29.0"
    },
    "peerDependenciesMeta": {
        "drizzle-orm": {
            "optional": false
        }
    },
    "devDependencies": {
        "@dilukangelo/api-forge-core": "workspace:*",
        "@types/bun": "latest",
        "bun-types": "^1.3.8",
        "drizzle-orm": "^0.29.0",
        "typescript": "^5.4.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dilukangelosl/API-Forge",
        "directory": "packages/storage-drizzle"
    },
    "keywords": [
        "api-forge",
        "drizzle",
        "orm",
        "storage",
        "oauth"
    ]
}